{
    "info": { "name": "Grid07 API", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
    "item": [
      {
        "name": "Create Post",
        "request": {
          "method": "POST", "url": "http://localhost:8080/api/posts",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": { "mode": "raw", "raw": "{\"authorId\": 1, \"authorType\": \"USER\", \"content\": \"Hello World!\"}" }
        }
      },
      {
        "name": "Like Post",
        "request": {
          "method": "POST", "url": "http://localhost:8080/api/posts/1/like",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": { "mode": "raw", "raw": "{\"userId\": 1}" }
        }
      },
      {
        "name": "Bot Comment (Guardrail Test)",
        "request": {
          "method": "POST", "url": "http://localhost:8080/api/posts/1/comments",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": { "mode": "raw", "raw": "{\"authorId\": 1, \"authorType\": \"BOT\", \"content\": \"Bot reply\", \"depthLevel\": 1, \"targetUserId\": 1}" }
        }
      },
      {
        "name": "Get Virality Score",
        "request": { "method": "GET", "url": "http://localhost:8080/api/posts/1/virality" }
      }
    ]
  }